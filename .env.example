# ===================================================================
# LIBRARY MANAGEMENT SYSTEM - DOCKER ENVIRONMENT VARIABLES
# ===================================================================
# This file contains all environment variables for Docker Compose setup
# Copy this to .env and update with your values

# ===================================================================
# 1. SECURITY
# ===================================================================
# JWT secret key for authentication (must be same for both apps)
# Generate a new one using: openssl rand -base64 32
JWT_SECRET_KEY=

# ===================================================================
# 2. DATABASE (PostgreSQL)
# ===================================================================
POSTGRES_DB=library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ===================================================================
# 3. MAIL (SMTP)
# ===================================================================
# Gmail SMTP settings (use app-specific password if using 2FA)
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# ===================================================================
# 4. PORTS (Docker Compose)
# ===================================================================
# Define ports to avoid conflicts with local services
# Database mapped to 5433 to avoid conflict with local Postgres (5432)
DATABASE_PORT=5433
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ===================================================================
# 5. OTHER
# ===================================================================
NODE_ENV=development
